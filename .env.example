# ====================
# Mindawaker 环境变量
# 复制此文件为 .env 并填入你的密钥
# cp .env.example .env
# ====================

# --------------------------------------------
# LLM API Keys
# --------------------------------------------
DEEPSEEK_API_KEY=sk-your-deepseek-key
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --------------------------------------------
# 图像生成 API Keys
# --------------------------------------------
# 火山引擎 (Jimeng T2I)
VOLC_ACCESS_KEY=your-volc-access-key
VOLC_SECRET_KEY=your-volc-secret-key

# Flux (piapi.ai)
FLUX_API_KEY=your-flux-api-key

# --------------------------------------------
# TTS API Keys (可选)
# --------------------------------------------
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastasia
COQUI_TTS_MODEL=tts_models/en/vctk/vits

# --------------------------------------------
# Media Service (可选)
# --------------------------------------------
MEDIA_SERVICE_DEFAULT_MEDIA_LIBRARY_ROOT=./media_library
MEDIA_SERVICE_DEFAULT_ANNOTATION_ROOT=./annotations
MEDIA_SERVICE_DEFAULT_WINDOW_ANNOTATION_ROOT=./window_annotations
MEDIA_SERVICE_CONTENT_PROVIDER=qwen2_5_vl
MEDIA_SERVICE_CONTENT_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
MEDIA_SERVICE_CONTENT_MODEL_ROOT=./models
MEDIA_SERVICE_CONTENT_DEVICE=auto
MEDIA_SERVICE_CONTENT_MAX_NEW_TOKENS=256

# --------------------------------------------
# 服务配置
# --------------------------------------------
CORS_ORIGINS=http://localhost:3000
HF_HOME=./cache/huggingface
LOG_LEVEL=INFO
LOG_DIR=app/assets/logs
